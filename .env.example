# Dev: прокси vite → orchestrator / provisioner / minio
VITE_ORCH_PROXY_TARGET=http://127.0.0.1:9092
VITE_PROV_PROXY_TARGET=http://127.0.0.1:19092
VITE_MINIO_PROXY_TARGET=http://127.0.0.1:9000

# API base paths (одинаково в dev и prod через nginx)
VITE_ORCH_API=/api/orch
VITE_PROV_API=/api/prov
VITE_MINIO_API=/api/minio
VITE_BULK_API=/api/bulk

# Лайв-превью: интервал обновления кадра (мс)
VITE_LIVE_PREVIEW_INTERVAL_MS=5000

# Basic auth (dev: vite middleware; prod: nginx htpasswd)
FRONTEND_AUTH_USER=admin
FRONTEND_AUTH_PASSWORD=af-admin

# Дефолтный промпт для AI-видео
VITE_DEFAULT_AI_PROMPT=котики на закате
